@tailwind base;
@tailwind components;
@tailwind utilities;

@import url('https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400&family=Instrument+Sans:wght@400;500;600&family=Newsreader:ital,opsz,wght@0,6..72,300;0,6..72,400;0,6..72,500;1,6..72,300;1,6..72,400&display=swap');

@layer base {
  body {
    @apply bg-pink-dark text-on-pink-primary antialiased;
    font-family: 'Instrument Sans', 'Inter', system-ui, sans-serif;
    font-size: 0.9375rem;
    line-height: 1.6;
    padding-top: 60px;
  }

  ::selection {
    background-color: #F5D6D6;
    color: #1A1512;
  }

  hr {
    border-color: #E8C4C4;
    border-width: 0.5px;
  }

  input[type="text"],
  input[type="email"],
  input[type="number"],
  input[type="password"],
  textarea,
  select {
    @apply bg-pink-light text-on-pink-primary rounded-none;
    font-family: 'Instrument Sans', system-ui, sans-serif;
    font-size: 0.9375rem;
    border: none;
    transition: background-color 0.15s ease;
  }

  input:focus,
  textarea:focus,
  select:focus {
    @apply outline-none ring-0;
    background-color: #FEFAFA;
  }

  ::placeholder {
    @apply text-on-pink-muted;
    font-style: normal;
  }
}

@layer components {
  .ornament {
    @apply text-center select-none;
    font-family: 'IBM Plex Mono', monospace;
    letter-spacing: 0.5em;
    font-size: 0.75rem;
    color: #A88B8B;
  }
  .ornament::before {
    content: '· · ·';
  }

  .rule {
    border-top: 0.5px solid #E8C4C4;
  }

  .rule-blue {
    border-top: 0.5px solid #7E95AD;
  }

  .label-mono {
    font-family: 'Instrument Sans', system-ui, sans-serif;
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: #8A6B6B;
  }

  .label-mono-blue {
    font-family: 'Instrument Sans', system-ui, sans-serif;
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: #5C7188;
  }

  /* Feed tiles */
  .tile-note {
    @apply bg-pink-light;
    padding: 1.25rem 1.5rem;
  }

  .tile-article {
    @apply bg-blue-dark;
    border: 4px solid #C5D3E0;
    padding: 1.25rem 1.5rem;
  }

  /* Cards */
  .card {
    @apply bg-pink-light;
    border: none;
    border-radius: 0;
  }

  .card-strong {
    @apply bg-pink-dark;
    border: none;
    border-radius: 0;
  }

  .card-blue {
    @apply bg-blue-dark;
    border: none;
    border-radius: 0;
  }

  .card-blue-light {
    @apply bg-blue-light;
    border: none;
    border-radius: 0;
  }

  /* Tab pills */
  .tab-pill {
    font-family: 'Instrument Sans', system-ui, sans-serif;
    font-size: 0.8125rem;
    font-weight: 500;
    letter-spacing: 0.03em;
    text-transform: uppercase;
    padding: 0.5rem 1rem;
    border: none;
    border-radius: 0;
    cursor: pointer;
    transition: background-color 0.15s ease, color 0.15s ease;
  }
  .tab-pill-active {
    background: #1A1512;
    color: #FFF0F0;
  }
  .tab-pill-inactive {
    @apply bg-pink-light text-on-pink-secondary;
  }
  .tab-pill-inactive:hover {
    @apply text-on-pink-primary;
    background: #F5E0E0;
  }

  /* Buttons */
  .btn {
    background: #1A1512;
    color: #FFF0F0;
    font-family: 'Instrument Sans', system-ui, sans-serif;
    font-size: 0.8125rem;
    font-weight: 500;
    letter-spacing: 0.03em;
    text-transform: uppercase;
    border: none;
    border-radius: 0;
    padding: 0.625rem 1.5rem;
    transition: background-color 0.15s ease;
    cursor: pointer;
  }
  .btn:hover { background: #3D3530; }
  .btn:disabled { opacity: 0.5; }

  .btn-soft {
    @apply bg-pink-light text-on-pink-primary;
    font-family: 'Instrument Sans', system-ui, sans-serif;
    font-size: 0.8125rem;
    font-weight: 500;
    letter-spacing: 0.03em;
    text-transform: uppercase;
    border: none;
    border-radius: 0;
    padding: 0.625rem 1.5rem;
    transition: background-color 0.15s ease;
    cursor: pointer;
  }
  .btn-soft:hover {
    background: #F5E0E0;
  }
}

@layer utilities {
  .sharp { border-radius: 0 !important; }
}
