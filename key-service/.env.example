# Database (shared with payment service)
DATABASE_URL=postgresql://platformpub:password@localhost:5432/platformpub

# KMS — 32 bytes hex (64 chars). Generate with: openssl rand -hex 32
# In production, replace this with a real KMS (AWS KMS, GCP KMS, Vault)
KMS_MASTER_KEY_HEX=<64 hex chars>

# Nostr service keypair — same key used by the payment service for receipt signing
# Generate with: node -e "const {generateSecretKey}=require('nostr-tools'); console.log(Buffer.from(generateSecretKey()).toString('hex'))"
PLATFORM_SERVICE_PRIVKEY=<64 hex chars>

# Server
PORT=3002
NODE_ENV=development
LOG_LEVEL=info
