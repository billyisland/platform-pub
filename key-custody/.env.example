# Database (shared with all services)
DATABASE_URL=postgresql://platformpub:password@localhost:5432/platformpub

# Account keypair encryption key — 32 bytes hex (64 chars)
# This key encrypts user Nostr private keys at rest.
# It must NOT be shared with the gateway or any other service.
# Generate with: openssl rand -hex 32
ACCOUNT_KEY_HEX=<64 hex chars>

# Platform service keypair — used to derive NIP-44 conversation keys when
# unwrapping content keys for readers. Must match the key used by key-service.
# Generate with: node -e "const {generateSecretKey}=require('nostr-tools'); console.log(Buffer.from(generateSecretKey()).toString('hex'))"
PLATFORM_SERVICE_PRIVKEY=<64 hex chars>

# Internal service secret — callers must send this in X-Internal-Secret header
# Generate with: openssl rand -base64 32
INTERNAL_SECRET=<base64 secret>

# Server
PORT=3004
NODE_ENV=development
LOG_LEVEL=info
