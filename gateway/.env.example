# Database (shared with payment and key services)
DATABASE_URL=postgresql://platformpub:password@localhost:5432/platformpub

# Session — minimum 32 characters. Generate with: openssl rand -base64 48
SESSION_SECRET=<at-least-32-characters>

# Cookie signing secret (can be the same as SESSION_SECRET)
COOKIE_SECRET=<at-least-32-characters>

# Account keypair encryption — 32 bytes hex (64 chars)
# Separate from the vault KMS key. Generate with: openssl rand -hex 32
ACCOUNT_KEY_HEX=<64 hex chars>

# Platform service keypair — same key used by payment + key services
# Used by the gateway for NIP-44 unwrapping (deriving conversation keys)
PLATFORM_SERVICE_PRIVKEY=<64 hex chars>

# Reader hash key — used to HMAC reader pubkeys in receipt events
# Generate with: openssl rand -hex 32
READER_HASH_KEY=<64 hex chars>

# Admin — comma-separated account UUIDs that can access /admin/* routes
# At launch, this is the founder's account ID
ADMIN_ACCOUNT_IDS=<uuid1>,<uuid2>

# Email provider: 'postmark', 'resend', or 'console' (dev default)
EMAIL_PROVIDER=console
# EMAIL_FROM=login@platform.pub
# POSTMARK_API_KEY=...
# RESEND_API_KEY=...

# Stripe
STRIPE_SECRET_KEY=sk_test_...

# Internal service URLs
PAYMENT_SERVICE_URL=http://localhost:3001
KEY_SERVICE_URL=http://localhost:3002
BLOSSOM_URL=http://localhost:3003

# App URL (for Stripe redirects, CORS, magic links)
APP_URL=http://localhost:3000

# Server
PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# Google OAuth (for "Sign in with Google")
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
