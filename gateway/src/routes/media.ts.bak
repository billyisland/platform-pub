import sharp from 'sharp'
import type { FastifyInstance } from 'fastify'
import { z } from 'zod'
import { pool } from '../../shared/src/db/client.js'
import { requireAuth, optionalAuth } from '../middleware/auth.js'
import logger from '../../shared/src/lib/logger.js'

// =============================================================================
// Media Routes
//
// POST /media/upload       — Upload image via Blossom proxy
// GET  /media/oembed       — Proxy oEmbed lookups
//
// Image uploads are proxied through the gateway to the Blossom server.
// oEmbed lookups are proxied to protect reader IP addresses from third-party
// embed providers.
// =============================================================================

const BLOSSOM_URL = process.env.BLOSSOM_URL ?? 'http://localhost:3000'
const MAX_FILE_SIZE = 10 * 1024 * 1024 // 10 MB
const ALLOWED_TYPES = new Set(['image/jpeg', 'image/png', 'image/gif', 'image/webp'])

// oEmbed provider endpoints
const OEMBED_PROVIDERS: Record<string, string> = {
  'youtube.com': 'https://www.youtube.com/oembed',
  'youtu.be': 'https://www.youtube.com/oembed',
  'vimeo.com': 'https://vimeo.com/api/oembed.json',
  'twitter.com': 'https://publish.twitter.com/oembed',
  'x.com': 'https://publish.twitter.com/oembed',
  'open.spotify.com': 'https://open.spotify.com/oembed',
}

export async function mediaRoutes(app: FastifyInstance) {

  // ---------------------------------------------------------------------------
  // POST /media/upload — upload an image via Blossom
  //
  // Accepts multipart/form-data with a single 'file' field.
  // Validates type and size, proxies to the Blossom server, records the
  // upload in media_uploads for moderation and quota tracking.
  // ---------------------------------------------------------------------------

  app.post('/media/upload', { preHandler: requireAuth }, async (req, reply) => {
    const uploaderId = req.session!.sub!

    try {
      // Parse multipart body
      const data = await req.file()
      if (!data) {
        return reply.status(400).send({ error: 'No file uploaded' })
      }

      // Validate MIME type
      if (!ALLOWED_TYPES.has(data.mimetype)) {
        return reply.status(400).send({
          error: `Unsupported file type: ${data.mimetype}. Allowed: JPEG, PNG, GIF, WebP`,
        })
      }

      // 1. Read the file into a buffer
      const originalBuffer = await data.toBuffer()
      
      // 2. Crunch the image (Resize to 1200px wide, convert to WebP for best compression)
      const fileBuffer = await sharp(originalBuffer)
        .resize(1200, null, { withoutEnlargement: true }) // Don't make small images bigger
        .webp({ quality: 80 }) // WebP is much smaller than JPEG/PNG
        .toBuffer()

      // 3. Compute SHA-256 of the CRUNCHED version (for deduplication)
      const { createHash } = await import('crypto')
      const sha256 = createHash('sha256').update(fileBuffer).digest('hex')

      // Check for duplicate
      const existing = await pool.query<{ blossom_url: string }>(
        'SELECT blossom_url FROM media_uploads WHERE sha256 = $1 LIMIT 1',
        [sha256]
      )
      if (existing.rows.length > 0) {
        return reply.status(200).send({
          url: existing.rows[0].blossom_url,
          sha256,
          duplicate: true,
        })
      }

      

// Standard Blossom POST upload to the root /
      const blossomRes = await fetch(`${BLOSSOM_URL}/`, {
        method: 'POST',
        headers: {
          'Content-Type': data.mimetype,
        },
        body: fileBuffer,
      })

      if (!blossomRes.ok && blossomRes.status !== 201 && blossomRes.status !== 200) {
        const errorBody = await blossomRes.text().catch(() => 'No body')
        throw new Error(`Blossom POST failed with status ${blossomRes.status}: ${errorBody}`)
      }

      // Return the PUBLIC URL for the browser
      const publicUrl = `https://platform.pub/media/${sha256}`

      // Record in media_uploads
      await pool.query(
        `INSERT INTO media_uploads (uploader_id, blossom_url, sha256, mime_type, size_bytes)
         VALUES ($1, $2, $3, $4, $5)`,
        [uploaderId, blossomUrl, sha256, data.mimetype, fileBuffer.length]
      )

      logger.info({ uploaderId, sha256, size: fileBuffer.length }, 'Media uploaded')

      return reply.status(201).send({
        url: blossomUrl,
        sha256,
        mimeType: data.mimetype,
        size: fileBuffer.length,
      })
    } catch (err) {
      logger.error({ err, uploaderId }, 'Media upload error')
      return reply.status(500).send({ error: 'Upload failed' })
    }
  })

  // ---------------------------------------------------------------------------
  // GET /media/oembed?url=... — proxy oEmbed lookups
  //
  // Fetches oEmbed metadata from supported providers on behalf of the client.
  // This prevents third-party providers from seeing the reader's IP address
  // during the metadata fetch phase.
  // ---------------------------------------------------------------------------

  app.get('/media/oembed', { preHandler: optionalAuth }, async (req, reply) => {
    const url = (req.query as { url?: string }).url
    if (!url) {
      return reply.status(400).send({ error: 'Missing url parameter' })
    }

    try {
      const parsed = new URL(url)
      const hostname = parsed.hostname.replace(/^www\./, '')

      const oembedEndpoint = OEMBED_PROVIDERS[hostname]
      if (!oembedEndpoint) {
        return reply.status(400).send({ error: 'Unsupported embed provider' })
      }

      const oembedUrl = `${oembedEndpoint}?url=${encodeURIComponent(url)}&format=json&maxwidth=680`

      const res = await fetch(oembedUrl, {
        headers: { 'User-Agent': 'Platform/1.5 (+https://platform.pub)' },
      })

      if (!res.ok) {
        return reply.status(res.status).send({ error: 'oEmbed lookup failed' })
      }

      const data = await res.json()

      return reply.status(200).send({
        type: data.type,
        title: data.title,
        authorName: data.author_name,
        authorUrl: data.author_url,
        providerName: data.provider_name,
        providerUrl: data.provider_url,
        thumbnailUrl: data.thumbnail_url,
        thumbnailWidth: data.thumbnail_width,
        thumbnailHeight: data.thumbnail_height,
        html: data.html,
        width: data.width,
        height: data.height,
      })
    } catch (err) {
      logger.error({ err, url }, 'oEmbed lookup error')
      return reply.status(500).send({ error: 'oEmbed lookup failed' })
    }
  })
}
